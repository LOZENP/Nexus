# ── helpers ──────────────────────────────────────────────────────────────────

def mkdir(path):
    os.makedirs(path, exist_ok=True)

def write(path, content):
    mkdir(os.path.dirname(path))
    with open(path, "w", encoding="utf-8") as f:
        f.write(content)
    print("  wrote:", os.path.relpath(path, NEXUS))

def copy_fix(src_rel, dst_rel):
    """Copy a Prometheus file into Nexus, fixing require paths."""
    src = os.path.join(PROM_SRC, src_rel)
    dst = os.path.join(NEXUS, "src", "nexus", dst_rel)
    mkdir(os.path.dirname(dst))
    with open(src, "r", encoding="utf-8") as f:
        text = f.read()
    text = text.replace('require("prometheus.', 'require("nexus.')
    text = text.replace("require('prometheus.", "require('nexus.")
    text = text.replace('"prometheus.compiler.expressions."', '"nexus.compiler.expressions."')
    text = text.replace('"prometheus.compiler.statements."',  '"nexus.compiler.statements."')
    with open(dst, "w", encoding="utf-8") as f:
        f.write(text)
    print("  copied:", os.path.relpath(dst, NEXUS))

